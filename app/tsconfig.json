{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "es2017"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react",
    "incremental": true,
    "outDir": "./dist/webpack_bundles/cjs/",
    "rootDir": "./src/",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noImplicitAny": true,
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/types/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.d.tsx",
    "src/types/**/*.d.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "lib"
  ],
  "typeRoots": [
    "./node_modules/@types",
    "./src"
  ]
}
